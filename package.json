{
  "name": "sigocr",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "native.cjs",
    "native.d.cts"
  ],
  "scripts": {
    "build:rs": "napi build --platform --release && mv index.js native.cjs",
    "build:ts": "tsup",
    "build": "pnpm build:rs && pnpm build:ts",
    "dev": "napi build --platform && mv index.js native.cjs && pnpm build:ts",
    "fixtures": "tsx __test__/fixtures/generate.ts",
    "test": "pnpm fixtures && vitest run",
    "bench": "pnpm fixtures && vitest bench",
    "type-check": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "release": "sh -c 'npm version $0 --no-git-tag-version && npx napi version && git add -A && git commit -m \"v$0\" && git tag \"v$0\" && git push origin main \"v$0\"'"
  },
  "napi": {
    "binaryName": "sigocr",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl",
      "x86_64-pc-windows-msvc"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@napi-rs/cli": "^3.5.1",
    "@types/node": "^25.3.3",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdf.js-extract": "^0.2.1",
    "pdf2json": "^4.0.2",
    "pdfjs-dist": "^5.5.207",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "unpdf": "^1.4.0",
    "vitest": "^4.0.18"
  }
}
